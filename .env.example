# ──────────────────────────────────────────────────────────────
# AutoDiag Backend – environment variables
# Copy this file to .env and fill in the values.
# DO NOT commit .env to source control.
# ──────────────────────────────────────────────────────────────

# Required – sign/verify JWT access tokens
JWT_SECRET=replace-with-a-strong-secret

# Required – Azure Storage Account connection string
# Retrieve with: az storage account show-connection-string \
#   --name <account> --resource-group <rg> --query connectionString -o tsv
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Blob container name for audio uploads (default: audio)
AZURE_STORAGE_CONTAINER=audio

# Azure Table Storage table names (created automatically on startup)
AZURE_TABLE_USERS=users
AZURE_TABLE_REFRESH_TOKENS=refreshtokens
AZURE_TABLE_AUDIO_RESULTS=audioresults

# AI classification model loaded locally via Hugging Face transformers
# The model is downloaded from the Hub on first run and cached automatically
AI_MODEL_NAME=laion/clap-htsat-unfused

# Comma-separated candidate labels for zero-shot audio classification
AI_DEFAULT_LABELS=engine_knock,engine_misfire,engine_idle,engine_normal,engine_overheating,engine_startup,engine_acceleration,engine_stall

# Local directory used when Azure Storage is unavailable (default: data/audio)
LOCAL_AUDIO_DIR=data/audio
